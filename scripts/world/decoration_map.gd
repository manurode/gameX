func _ready() -> void:
	_paint_objects()


func _paint_objects() -> void:
	for y in OBJECT_ROWS.size():
		var values := OBJECT_ROWS[y].split(",")
		for x in values.size():
			var gid := int(values[x])
			if gid <= 0:
				continue
			set_cell(MAP_OFFSET + Vector2i(x, y), 0, _gid_to_atlas(gid))


func _gid_to_atlas(gid: int) -> Vector2i:
	var index := gid - 1
	return Vector2i(index % 18, index / 18)
