func _ready() -> void:
	_paint_layer(TERRAIN_ROWS)
	_paint_layer(OBJECT_ROWS)


func _paint_layer(rows: Array[String]) -> void:
	for y in rows.size():
		var values := rows[y].split(",")
		for x in values.size():
			var gid := int(values[x])
			if gid <= 0:
				continue
			set_cell(MAP_OFFSET + Vector2i(x, y), 0, _gid_to_atlas(gid))


func _gid_to_atlas(gid: int) -> Vector2i:
	var index := gid - 1
	return Vector2i(index % 18, index / 18)
